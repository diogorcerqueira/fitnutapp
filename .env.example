# Google OAuth 2.0 — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ExerciseDB via RapidAPI — https://rapidapi.com/
# Opcional: apenas usado como fallback se BD local tiver < 5 resultados
EXERCISEDB_API_KEY=

# Modelo LLM (default: openai/gpt-oss-20b:free)
LLM_MODEL=openai/gpt-oss-20b:free
